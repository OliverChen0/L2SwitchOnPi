//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = debug testing-script vlanlist <vlan_list>
PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE  = ICLI_CMD_MODE_EXEC

CMD_VAR   =
CMD_VAR   =
CMD_VAR   =
CMD_VAR   = vlanlist

VARIABLE_BEGIN
    u32             i, idx;
    vtss_vlan_list_t  vids;
    vtss_vlan_list_t                *vls = &vids;
VARIABLE_END

CODE_BEGIN

        memset(vls, 0, sizeof(*vls));
        for (i = 0; i < vlanlist->cnt; i++) {
            for (idx = vlanlist->range[i].min; idx <= vlanlist->range[i].max; idx++) {
                if (idx > MRDC_VID_RESERVED) {
                    ICLI_PRINTF("%% Failed to build vlan mask\n");
                    return MRDC_RC_ERROR;
                }
                mgmt_types_vlan_list_bit_value_set(vls, idx);
            }
        }

        for (i = 0; i < sizeof(vids.data)/128; i++) {
            ICLI_PRINTF("%dKTo%dK\n", i, i + 1);
            for (idx = i * 128; idx < (i + 1) * 128 - 1; idx ++) {
                ICLI_PRINTF("%u,", vids.data[idx]);
            }
            ICLI_PRINTF("%u\n", vids.data[idx]);
        }

CODE_END
CMD_END

//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = debug vtss-ifindex-getnext { port | llag | vlan | loopback } { first | <uint> }
PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE  = ICLI_CMD_MODE_EXEC

CMD_VAR   =
CMD_VAR   =
CMD_VAR   = b_port
CMD_VAR   = b_llag
CMD_VAR   =
CMD_VAR   = b_loopback
CMD_VAR   = b_first
CMD_VAR   = previous_

VARIABLE_BEGIN
    mrdc_ifindex_t  next;
    u32             enumerate_types;
    u32             type;
    mrdc_rc         rc;
    mrdc_ifindex_t  previous;
VARIABLE_END

CODE_BEGIN
    previous = mrdc_ifindex_cast_from_u32_0(previous_);
    if ( b_port ) {
        type = MRDC_IFINDEX_TYPE_PORT;
        enumerate_types = 1 << MRDC_IFINDEX_TYPE_PORT;
    } else if ( b_llag ) {
        type = MRDC_IFINDEX_TYPE_LLAG;
        enumerate_types = 1 << MRDC_IFINDEX_TYPE_LLAG;
    } else if (b_loopback) {
        type = MRDC_IFINDEX_TYPE_LOOPBACK;
        enumerate_types = 1 << MRDC_IFINDEX_TYPE_LOOPBACK;
    } else {
        type = MRDC_IFINDEX_TYPE_VLAN;
        enumerate_types = 1 << MRDC_IFINDEX_TYPE_VLAN;
    }

    if ( b_first ) {
        rc = mrdc_ifindex_getnext_by_type( NULL, &next, enumerate_types );
    } else {
        rc = mrdc_ifindex_getnext_by_type( &previous, &next, enumerate_types );
    }

    if ( rc == MRDC_RC_OK ) {
        ICLI_PRINTF("next = %u\n", MRDC_IFINDEX_PRINTF_ARG(next));
    } else {
        ICLI_PRINTF("%% Fail to get next for type %u\n", type);
    }
CODE_END
CMD_END


//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = debug vtss-ifindex-iterate { all-type | port | llag | vlan | loopback } { first | <uint> } [ check-exist ] [iterate-cnt <int>]
PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE  = ICLI_CMD_MODE_EXEC

CMD_VAR   =
CMD_VAR   =
CMD_VAR   = b_all
CMD_VAR   = b_port
CMD_VAR   = b_llag
CMD_VAR   = b_vlan
CMD_VAR   = b_loopback
CMD_VAR   = b_first
CMD_VAR   = previous_
CMD_VAR   = b_check
CMD_VAR   = b_iterate_cnt
CMD_VAR   = iterate_cnt

VARIABLE_BEGIN
    mrdc_ifindex_t  next, previous;
    u32             enumerate_types = 0;
    int             cnt=1;
    mrdc_rc         rc;
    char            buf[36];
VARIABLE_END

CODE_BEGIN
    previous = mrdc_ifindex_cast_from_u32_0(previous_);

    if (b_all) {
        enumerate_types = MRDC_IFINDEX_GETNEXT_ALL;
    }

    if (b_port) {
        enumerate_types |= MRDC_IFINDEX_GETNEXT_PORTS;
    }

    if (b_llag) {
        enumerate_types |= MRDC_IFINDEX_GETNEXT_LLAGS;
    }

    if (b_vlan) {
        enumerate_types |= MRDC_IFINDEX_GETNEXT_VLANS;
    }

    if (b_loopback) {
        enumerate_types |= MRDC_IFINDEX_GETNEXT_LOOPBACK;
    }

    if (b_iterate_cnt) {
        cnt = iterate_cnt;
    }

    if (b_first) {
        rc = mrdc_ifindex_iterator( NULL, &next, enumerate_types, b_check );
        if (rc == MRDC_RC_OK) {
            (void)mrdc_ifindex2str(buf, sizeof(buf), next);
            ICLI_PRINTF("prev=NULL, next=%d [%s]\n", MRDC_IFINDEX_PRINTF_ARG(next), buf);
        } else {
            ICLI_PRINTF("prev=NULL, next=N/A(%d)\n", rc);
            return ICLI_RC_OK;
        }
        cnt--;
    } else {
        rc = mrdc_ifindex_iterator( &previous, &next, enumerate_types, b_check );
        if (rc == MRDC_RC_OK) {
            (void)mrdc_ifindex2str(buf, sizeof(buf), next);
            ICLI_PRINTF("prev=%d, next=%d [%s]\n", MRDC_IFINDEX_PRINTF_ARG(previous), MRDC_IFINDEX_PRINTF_ARG(next), buf);
            if (mrdc_ifindex_cast_to_u32(previous) >= mrdc_ifindex_cast_to_u32(next)) {
                ICLI_PRINTF("Error! prev >= next\n");
            }
        } else {
            ICLI_PRINTF("prev=%d, next=N/A(%d)\n", MRDC_IFINDEX_PRINTF_ARG(previous), rc);
            return ICLI_RC_OK;
        }
        cnt--;
    }

    for (; cnt > 0; cnt--) {
        previous = next;

        rc = mrdc_ifindex_iterator( &previous, &next, enumerate_types, b_check );
        if (rc == MRDC_RC_OK) {
            (void)mrdc_ifindex2str(buf, sizeof(buf), next);
            ICLI_PRINTF("prev=%d, next=%d [%s]\n", MRDC_IFINDEX_PRINTF_ARG(previous), MRDC_IFINDEX_PRINTF_ARG(next), buf);
            if (mrdc_ifindex_cast_to_u32(previous) >= mrdc_ifindex_cast_to_u32(next)) {
                ICLI_PRINTF("Error! prev >= next\n");
            }
        } else {
            ICLI_PRINTF("prev=%d, next=N/A(%d)\n", MRDC_IFINDEX_PRINTF_ARG(previous), rc);
            return ICLI_RC_OK;
        }
    }/* for */


CODE_END
CMD_END


//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = debug module support <word>
PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE  = ICLI_CMD_MODE_EXEC

CMD_VAR   =
CMD_VAR   =
CMD_VAR   =
CMD_VAR   = module

HELP      = ##ICLI_HELP_DEBUG
HELP      = Debug Module Support Info
HELP      =

VARIABLE_BEGIN

VARIABLE_END

CODE_BEGIN
    if (module == NULL) {
        return ICLI_RC_OK;
    }

    if (strcmp(module, "sntp") == 0) {
        ICLI_PRINTF("Not support\n");
        return ICLI_RC_OK;
    }

    if (strcmp(module, "ntp") == 0) {
#if defined(MRDC_SW_OPTION_NTP)
        ICLI_PRINTF("Supported\n");
#else
        ICLI_PRINTF("Not support\n");
#endif
        return ICLI_RC_OK;
    }

    if (strcmp(module, "smon") == 0) {
#if defined(MRDC_SW_OPTION_SMON)
        ICLI_PRINTF("Supported\n");
#else
        ICLI_PRINTF("Not support\n");
#endif
        return ICLI_RC_OK;
    }

CODE_END
CMD_END

//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = debug testing-script portlist-index <port_type_list>
PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE  = ICLI_CMD_MODE_EXEC

CMD_VAR   =
CMD_VAR   =
CMD_VAR   =
CMD_VAR   = plist

VARIABLE_BEGIN
    u8      data[__PORT_LIST_ARR_SIZE];
    u32     i;
    u32     j;
    u32     isid;
    u32     iport;
VARIABLE_END

CODE_BEGIN
    // set array
    memset(data, 0, __PORT_LIST_ARR_SIZE);
    if (plist) {
        for (i = 0; i < plist->cnt; ++i) {
            for (j = 0; j < plist->switch_range[i].port_cnt; ++j) {
                isid  = plist->switch_range[i].isid;
                iport = plist->switch_range[i].begin_iport + j;
                if (_port_list_stackable_set(isid, iport, data) == FALSE) {
                    ICLI_PRINTF("%% Fail to set port list for (%u, %u)\n", isid, iport);
                    return ICLI_RC_ERROR;
                }
            }
        }
    }

    // output
    for (i = 0; i < (__PORT_LIST_ARR_SIZE - 1); ++i ) {
        ICLI_PRINTF("%u,", data[i]);
    }
    ICLI_PRINTF("%u\n", data[i]);
CODE_END
CMD_END
